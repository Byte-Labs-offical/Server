# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Optional: a single guild (server) ID to register slash commands to.
# When set, commands register instantly to that one server (ideal for development).
# When left blank, commands register globally (may take up to ~1 hour to appear).
GUILD_ID=

# Web dashboard / Express
PORT=3000

# Session encryption (required for login sessions)
SESSION_SECRET=your_session_secret_here

# Discord OAuth2 (required for dashboard login)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback
