# Required
DISCORD_TOKEN=your_bot_token_here

# Optional (recommended for dev)
GUILD_ID=your_server_id

# Web dashboard / Express
PORT=3000

# Session encryption (required for login sessions)
SESSION_SECRET=some_random_long_secret

# Discord OAuth2 (required for dashboard login)
DISCORD_CLIENT_ID=your_app_client_id
DISCORD_CLIENT_SECRET=your_app_client_secret
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback